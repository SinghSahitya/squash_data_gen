# BigQuery (defaults to axis-max-life project credentials)
BIGQUERY_PROJECT=axis-max-life
BIGQUERY_KEY_FILE=D:\Startup\dummy_data\axis-max-life-dbc75b2c6913.json
BIGQUERY_DATASET=insurance_analytics

# Zendesk (get from: Admin Center > Apps & Integrations > APIs > Zendesk API)
ZENDESK_SUBDOMAIN=your-subdomain
ZENDESK_EMAIL=your-email@example.com
ZENDESK_API_TOKEN=your-api-token-here

# PostHog (get from: Project Settings > Project API Key for ingestion)
POSTHOG_HOST=https://us.posthog.com
POSTHOG_PROJECT_API_KEY=phc_your-project-api-key-here

# NVIDIA LLM (get free key from: https://build.nvidia.com)
# If not set, falls back to hardcoded templates (still works, just less varied)
NVIDIA_API_KEY=nvapi-your-key-here
NVIDIA_MODEL=meta/llama-3.3-70b-instruct
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
